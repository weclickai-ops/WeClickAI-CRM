# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service role bypasses RLS — used ONLY by the scraper cron. Never expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Google Places (scraper) ----
GOOGLE_MAPS_API_KEY=your-google-places-key

# ---- Cron auth (protects /api/cron/campaigns) ----
CRON_SECRET=make-a-long-random-string

# ---- App ----
NEXT_PUBLIC_APP_NAME=WeClick AI CRM
